# Vision model credentials (Gemini Developer API key from Google AI Studio).
# Required only for the live judge adapter; the fake judge and the test suite
# need no key.
GEMINI_API_KEY=

# Optional: override the default Gemini Flash-class model.
GEMINI_MODEL=gemini-2.5-flash

# Supabase persistence (Postgres + Storage). Required only for the live
# persistence path; with these unset the app uses the in-memory stores, and the
# test suite + build need none. Set all three to switch the stores to Supabase:
# run supabase/migrations/0001_init.sql and create a PRIVATE Storage bucket whose
# name matches SUPABASE_STORAGE_BUCKET. The server uses the service-role key
# (which bypasses RLS) — keep it secret; never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=chore-photos
