# Copy to .env and fill in. The real .env is gitignored — never commit secrets.

# ---- Vision judge ----
# The judge has two live adapters behind one seam; the fake judge and the test
# suite need no key. If BOTH keys are set, ANTHROPIC takes precedence.
JUDGE_ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
JUDGE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Supabase (Postgres + Auth + Storage) ----
# All optional. With no SUPABASE_<TARGET>_* block => in-memory stores + legacy
# no-login behavior (keyless mode).
#
# Both projects' keys live here under SUPABASE_STAGE_* / SUPABASE_PROD_*, and
# SUPABASE_TARGET selects which one local `npm run dev` and the gated
# `npm run test:supabase` use. A resolver (scripts/resolve-supabase-env.mjs)
# copies the selected block onto the canonical names the app reads
# (SUPABASE_URL / _SERVICE_ROLE_KEY / _ANON_KEY / _STORAGE_BUCKET and the
# browser-inlined NEXT_PUBLIC_SUPABASE_*) — DO NOT set those canonical names
# here; they are generated into .env.local. The deployed app does not use any of
# this: Vercel injects the canonical names per-environment at build time.
#
# Default is `stage` (safety): local dev + tests can never touch production
# unless you deliberately set SUPABASE_TARGET=prod.
SUPABASE_TARGET=stage          # stage | prod

# service_role bypasses RLS — keep secret, never expose to the browser.
# anon is public by design and is what the browser/SSR auth clients use.
SUPABASE_STAGE_URL=
SUPABASE_STAGE_SERVICE_ROLE_KEY=
SUPABASE_STAGE_ANON_KEY=
# SUPABASE_STAGE_STORAGE_BUCKET=chore-photos   # optional; defaults to chore-photos

SUPABASE_PROD_URL=
SUPABASE_PROD_SERVICE_ROLE_KEY=
SUPABASE_PROD_ANON_KEY=
# SUPABASE_PROD_STORAGE_BUCKET=chore-photos    # optional; defaults to chore-photos
