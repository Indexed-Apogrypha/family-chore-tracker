# Vision model credentials. The judge has two live adapters behind one seam; the
# fake judge and the test suite need no key. If BOTH keys are set, ANTHROPIC takes
# precedence (Claude is the compliance-preferred vendor for children's images —
# see docs/compliance.md).

# Anthropic Claude API key (from console.anthropic.com). Set this to use the
# Claude vision judge. The judge reads JUDGE_ANTHROPIC_API_KEY first, then
# ANTHROPIC_API_KEY. In Claude Code on the web, set JUDGE_ANTHROPIC_API_KEY in the
# environment config — the plain ANTHROPIC_API_KEY name is reserved by Claude Code
# for its own account auth and isn't passed through to the app. Locally, either works.
JUDGE_ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY=
# Optional: override the default Claude model (a Gemini Flash-class alternative).
CLAUDE_MODEL=claude-sonnet-4-6

# Gemini Developer API key (from Google AI Studio). Set this to use the Gemini
# vision judge instead.
GEMINI_API_KEY=
# Optional: override the default Gemini Flash-class model.
GEMINI_MODEL=gemini-2.5-flash

# Supabase (Postgres + Auth + Storage). All optional. With the URL + keys unset
# the app uses the in-memory stores AND the legacy single-implicit-family /
# role-by-URL behavior with no login — and the test suite + build need none.
#
# PERSISTENCE turns on when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set: run
# the migrations in order (supabase/migrations/0001_init.sql, 0002_accounts.sql,
# 0003_auth.sql, 0004_storage_rls.sql) and create a PRIVATE Storage bucket named
# SUPABASE_STORAGE_BUCKET. The service-role key BYPASSES RLS — keep it secret; never
# expose it to the browser. With only these set the app stays single-family under the
# service role (the 0002/0003/0004 RLS policies are present but dormant).
#
# AUTH turns on when SUPABASE_ANON_KEY is ALSO set: real Supabase Auth + per-family
# RLS. Login becomes required, and the dormant RLS policies enforce, because
# user-facing reads/writes run through the authenticated anon-key client instead of
# the service role. Manual prerequisite: in the Supabase Auth settings turn OFF
# "Confirm email" for v1 — parents self-register with email + password and need an
# immediate session; children are parent-provisioned (no self-registration).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# NOTE: 0004_storage_rls.sql hard-codes this bucket name as a SQL literal (migrations
# can't read env) — keep them in sync if you change it.
SUPABASE_STORAGE_BUCKET=chore-photos
