# Copy to .env and fill in. The real .env is gitignored — never commit secrets.

# ---- Vision judge ----
# The judge has two live adapters behind one seam; the fake judge and the test
# suite need no key. If BOTH keys are set, ANTHROPIC takes precedence.
JUDGE_ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
JUDGE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Supabase (Postgres + Auth + Storage) ----
# All optional. Unset => in-memory stores + legacy no-login behavior.
# PERSISTENCE: set SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (service role bypasses
#   RLS — keep secret, never expose to the browser).
# AUTH: additionally set SUPABASE_ANON_KEY for real Auth + per-family RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=chore-photos
# Browser-visible (anon key is public by design). Required for real Auth in the
# App Router (the @supabase/ssr clients). Mirror SUPABASE_URL / SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
